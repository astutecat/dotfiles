output eDP-1 {
  alias $INTERNAL
  scale 1.5
  position 0,0
  mode 2560x1600@90
}

output HDMI-A-1 {
  scale 1
  position 1750,0
  alias $EXTERNAL
}

output "Acer Technologies VG271U 0x0251929A" {
  alias $HOME
  scale 1
  mode 2560x1440@143.999
  position 1710,0
}

output "Lenovo Group Limited P27QD-40" {
  alias $WORK
  scale 1
  mode 2560x1440
}

profile entelios_office {
  output $INTERNAL enable
  output DP-6 enable position 1710,0
  output DP-9 enable position 4270,0
}

profile home_office {
  output $HOME enable
  output $INTERNAL enable
}

profile hdmi {
  output $INTERNAL enable
  output $EXTERNAL enable
}

profile {
  output $INTERNAL enable
}
