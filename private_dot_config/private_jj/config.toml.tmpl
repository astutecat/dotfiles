[ui]
pager = "cat"
default-command = ["log", "--reversed"]

[user]
name = "{{ .git.name }}"
email = "{{ .git.email }}"

[aliases]
push = ["util", "exec", "--", "jj-pre-push", "--checker", "prek", "push"]
fetch = ["git", "fetch"]
rlog = ["log", "--reversed"]

[remotes.origin]
auto-track-created-bookmarks = "*"
